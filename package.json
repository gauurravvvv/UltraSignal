{
  "name": "ultrasignalapi-repo",
  "version": "26.1.0",
  "description": "",
  "main": "dist/src/app.js",
  "scripts": {
    "prepare": "husky",
    "clean": "rimraf ./dist",
    "copy-files": "node scripts/copy-files.js",
    "build": "npm run clean && tsc && npm run copy-files",
    "prestart": "npm run build",
    "start": "node ./dist/src/app.js",
    "start:cluster": "pm2 start pm2.config.js --env production",
    "stop": "pm2 stop ultrasignalapi-repo",
    "reload": "pm2 reload ultrasignalapi-repo",
    "logs": "pm2 logs ultrasignalapi-repo",
    "test": "mocha test/*",
    "dev": "nodemon --watch src --ext ts,json --exec ts-node src/app.ts",
    "local": "cross-env NODE_ENV=local nodemon --watch src --ext ts,json --exec ts-node src/app.ts",
    "dev:sync": "cross-env DB_SYNC=true nodemon --watch src --ext ts,json --exec ts-node src/app.ts",
    "dev:clear": "cross-env DB_CLEAR=true ts-node src/app.ts",
    "local:sync": "cross-env NODE_ENV=local DB_SYNC=true nodemon --watch src --ext ts,json --exec ts-node src/app.ts",
    "local:clear": "cross-env NODE_ENV=local DB_CLEAR=true ts-node src/app.ts",
    "typeorm": "node --require ts-node/register ./node_modules/typeorm/cli.js",
    "deploy": "git pull && npm run build && pm2 reload pm2.config.js --env production"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "engines": {
    "node": ">=20.0.0",
    "npm": ">=10.0.0"
  },
  "dependencies": {
    "@aws-sdk/client-ses": "^3.967.0",
    "@types/snowflake-sdk": "^1.6.24",
    "bcrypt": "^6.0.0",
    "compression": "^1.8.1",
    "cors": "^2.8.6",
    "crypto-js": "^4.2.0",
    "csv-parse": "^6.2.1",
    "exceljs": "^4.4.0",
    "express": "^4.22.1",
    "express-rate-limit": "^8.4.0",
    "handlebars": "^4.7.9",
    "helmet": "^8.1.0",
    "joi": "^17.13.3",
    "jsonwebtoken": "^9.0.3",
    "jspdf": "^4.2.1",
    "jspdf-autotable": "^5.0.7",
    "morgan": "^1.10.1",
    "mssql": "^12.5.4",
    "multer": "^2.1.1",
    "mysql2": "^3.22.3",
    "ncp": "^2.0.0",
    "nodemailer": "^8.0.7",
    "oracledb": "^6.10.0",
    "pg": "^8.20.0",
    "pm2": "^5.4.3",
    "qs": "^6.15.0",
    "reflect-metadata": "^0.2.2",
    "snowflake-sdk": "^2.4.2",
    "typeorm": "^0.3.28",
    "validator": "^13.15.26",
    "winston": "^3.19.0",
    "winston-daily-rotate-file": "^5.0.0"
  },
  "devDependencies": {
    "@types/bcrypt": "^6.0.0",
    "@types/compression": "^1.8.1",
    "@types/cors": "^2.8.19",
    "@types/crypto-js": "^4.2.2",
    "@types/express": "^4.17.25",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/morgan": "^1.9.10",
    "@types/multer": "^2.1.0",
    "@types/node": "^20.19.39",
    "@types/nodemailer": "^6.4.23",
    "@types/pg": "^8.20.0",
    "@types/qs": "^6.15.0",
    "@types/validator": "^13.15.10",
    "cross-env": "^10.1.0",
    "husky": "^9.1.7",
    "nodemon": "^3.1.14",
    "prettier": "^3.8.1",
    "rimraf": "^6.1.3",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.7.3"
  }
}
