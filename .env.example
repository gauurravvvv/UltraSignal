# =====================================================================
# UltraSignalAPI-Repo — Environment template (.env.example)
#
# Copy to `.env` and fill in real values. .env is gitignored; this
# template is the canonical list of every variable the BE reads.
# Every variable below is consumed in config/config.ts.
# =====================================================================

# ── Database ─────────────────────────────────────────────────────────
# Master Postgres database — stores platform-level entities (super
# admins, clients, master audit logs). Each tenant client also has
# its own database registered in the master DB; those credentials live
# in the client's `database` row, not here.
DB_TYPE=postgres
DB_HOST=localhost
DB_PORT=5432
DB_NAME=UltraSignal
DB_USER=postgres
DB_PASSWORD=your_db_password

# DB_LOGGING: when "true" TypeORM logs every SQL query to the BE
# console. Useful in dev, noisy in prod — leave false in production.
DB_LOGGING=false

# DB_SYNC: when "true" TypeORM creates/updates DB schema from entity
# decorators on boot. NEVER enable in production — auto-DDL on a live
# database corrupts data. Used only during client onboarding flows.
DB_SYNC=false

# DB_CLEAR: when "true" wipes the database on boot. NEVER enable
# anywhere except a throwaway local dev box. Used by integration test
# tear-down.
DB_CLEAR=false

# ── Super Admin bootstrap ────────────────────────────────────────────
# Used by the first-boot onboarding (src/shared/helpers/system/onboardDB.ts)
# to seed the platform's master_admin account. After the first boot
# the values are baked into the DB row and changing them here has no
# effect on the existing admin.
SYSTEM_ADMIN_FIRST_NAME=Super
SYSTEM_ADMIN_LAST_NAME=Admin
SYSTEM_ADMIN_USER_NAME=ultrasignal_admin
SYSTEM_ADMIN_EMAIL=admin@yourdomain.com
SYSTEM_ADMIN_PASSWORD=YourPassword@123

# ── Platform "super" client ──────────────────────────────────────────
# The default client the super admin belongs to. Like the bootstrap
# admin above, these are seeded once and ignored thereafter.
SUPER_CLIENT_NAME=UltraSignal
SUPER_CLIENT_DESC=UltraSignal Master Client

# ── URLs ─────────────────────────────────────────────────────────────
# FE_URL is the origin allowed by CORS and embedded into outbound
# email links (welcome, password reset, etc.). Must match wherever
# the Angular app is actually hosted.
# WEB_URL is the marketing / docs site host used in some email footers.
FE_URL=http://localhost:4200
WEB_URL=http://localhost:4201

# ── Platform master key ──────────────────────────────────────────────
# 32 random bytes, base64-encoded. Wraps every per-org Data
# Encryption Key (DEK); the DEK in turn encrypts datasource
# passwords, SMTP creds, user passwords.
#
# Generate with:   openssl rand -base64 32
#
# If unset or invalid, the BE refuses to start. No fallback.
# DO NOT commit a real master key to git.
ULTRASIGNAL_MASTER_KEY=change_me_to_base64_of_32_random_bytes

# LEGACY_MASTER_SECRET_KEY: only set during the rolling upgrade from
# the old crypto-js scheme. The migration helper uses it to unwrap
# legacy master-DB passwords. Remove once every org has been touched
# by an authed request after the upgrade.
# LEGACY_MASTER_SECRET_KEY=your_old_master_secret

# ── JWT ──────────────────────────────────────────────────────────────
# JWT_SECRET_KEY signs every access / refresh / setup token. The BE
# refuses to start if it's unset. Use a long random string (≥64 chars).
# Rotating this invalidates every session in flight; users must log in
# again.
JWT_SECRET_KEY=change_this_to_a_random_64_char_string

# Token lifetimes:
#   SESSION_EXPIRE_TIME       legacy session idle-cap in minutes (0 = off)
#   ACCESS_TOKEN_EXPIRY       short-lived bearer token (FE auto-refreshes)
#   REFRESH_TOKEN_EXPIRY_DAYS long-lived refresh token, server-rotated
#   SETUP_TOKEN_EXPIRY_HOURS  one-time link in welcome / password-set emails
SESSION_EXPIRE_TIME=30
ACCESS_TOKEN_EXPIRY=15m
REFRESH_TOKEN_EXPIRY_DAYS=7
SETUP_TOKEN_EXPIRY_HOURS=72

# ── Email (SMTP) ─────────────────────────────────────────────────────
# Outbound mail for welcome, password-reset OTP, and reset-success
# notifications. SMTP_PASS is an app-specific password (Gmail) /
# API key (SES, Mailgun, etc.) — never the account's login password.
# If you don't want email in dev, leave these blank; nodemailer will
# refuse to send and the controllers log a warning.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password
SMTP_FROM=your_email@gmail.com
